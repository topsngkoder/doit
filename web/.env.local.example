NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# Service role — только на сервере, для cron-воркера outbox (RLS не мешает). Не коммитить.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Публичный origin веб-приложения (без завершающего /). Нужен воркеру email outbox для абсолютных ссылок в письмах (NT8.x).
NEXT_PUBLIC_APP_URL=https://your-app.example.com
# Секрет вызова GET/POST /api/cron/process-notification-outbox (Authorization: Bearer …). На Vercel можно задать CRON_SECRET — тогда подойдёт и встроенный cron.
NOTIFICATION_OUTBOX_CRON_SECRET=long_random_string
# Resend: https://resend.com — API key и verified from (или onboarding@resend.dev для тестов).
RESEND_API_KEY=re_xxxxxxxx
NOTIFICATION_EMAIL_FROM=Doit <onboarding@resend.dev>
