NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# Service role — только на сервере, для cron-воркера outbox (RLS не мешает). Не коммитить.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Публичный origin веб-приложения (без завершающего /). Нужен воркеру email outbox для абсолютных ссылок в письмах (NT8.x).
NEXT_PUBLIC_APP_URL=https://your-app.example.com
# Секрет вызова GET/POST /api/cron/process-notification-outbox (Authorization: Bearer …). На Vercel можно задать CRON_SECRET — тогда подойдёт и встроенный cron.
NOTIFICATION_OUTBOX_CRON_SECRET=long_random_string
# Опционально: отдельный секрет для GET/POST /api/cron/yandex-disk-cleanup (иначе используется NOTIFICATION_OUTBOX_CRON_SECRET или CRON_SECRET).
# YANDEX_DISK_CLEANUP_CRON_SECRET=long_random_string
# Resend: https://resend.com — API key и verified from (или onboarding@resend.dev для тестов).
RESEND_API_KEY=re_xxxxxxxx
NOTIFICATION_EMAIL_FROM=Doit <onboarding@resend.dev>
# Яндекс.Диск (интеграция доски): только на сервере, не префиксировать NEXT_PUBLIC_.
# Регистрация OAuth: https://oauth.yandex.ru — redirect URI должен совпадать с YANDEX_DISK_OAUTH_REDIRECT_URI.
# В приложении включите доступ к Диску: «Чтение всего Диска» + «Запись в любом месте Диска» (cloud_api:disk.read / cloud_api:disk.write).
YANDEX_DISK_OAUTH_CLIENT_ID=d3769a85a27c476699e007ff23b13ab1
YANDEX_DISK_OAUTH_CLIENT_SECRET=de42dc40507f4a57a1d8bd8dc024bd6f
YANDEX_DISK_OAUTH_REDIRECT_URI=https://your-app.example.com/api/yandex-disk/oauth/callback
# Случайная строка ≥32 символов для шифрования токенов в БД (YDB2.2). Менять нельзя без потери расшифровки уже сохранённых токенов.
YANDEX_DISK_TOKEN_ENCRYPTION_KEY=25fWNagz/2thTnvlDmEYkVAb35UMuXSiCDt8DsbnNNO1ydzdP4B6HTswSU1vWeJJ

