{
  "name": "doit-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "cf:patch-opennext": "node scripts/patch-opennext-windows-paths.mjs",
    "preview": "opennextjs-cloudflare build && npm run cf:patch-opennext && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && npm run cf:patch-opennext && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:migrate": "node scripts/run-migrations.js",
    "create-dev-users": "node --env-file=.env.local scripts/create-dev-users.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@opennextjs/cloudflare": "^1.18.1",
    "@supabase/ssr": "^0.5.1",
    "@supabase/supabase-js": "^2.48.0",
    "next": "^15.5.14",
    "pg": "^8.20.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.5.14",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.0",
    "wrangler": "^4.81.0"
  }
}
